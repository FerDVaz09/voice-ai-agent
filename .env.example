# ============================================================
# Vapi Config
# ============================================================
VAPI_API_KEY=your_vapi_api_key
VAPI_PHONE_NUMBER=your_vapi_phone_number
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id
VAPI_ASSISTANT_ID=your_vapi_assistant_id

# Secret para validar la firma de los webhooks entrantes de Vapi
# Configúralo también en el panel de Vapi → Webhook Secret
VAPI_WEBHOOK_SECRET=your_webhook_secret

# ============================================================
# Database Config (Local Postgres via Docker)
# ============================================================
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/voice_ai

# ============================================================
# LLM Config (Groq)
# ============================================================
GROQ_API_KEY=your_groq_api_key

# ============================================================
# Seguridad API
# ============================================================
# API key requerida en el header X-API-Key para /calls/outbound
OUTBOUND_API_KEY=your_outbound_api_key

# Orígenes permitidos en CORS (separados por coma)
# Ejemplo producción: https://tudominio.com,https://app.tudominio.com
# Dejar en * solo para desarrollo local
ALLOWED_ORIGINS=*
